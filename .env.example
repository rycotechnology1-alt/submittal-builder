# =============================================================================
# Submittal Builder — environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` (gitignored) and fill in values as accounts
# come online. Phase 0 of the build plan provisions every service listed below.
#
# Naming convention:
#   *_DEV   = local dev / Neon dev branch / dev S3 bucket
#   *_PROD  = production (filled in later; not needed for local dev)
#
# Never commit `.env.local` or any file containing real secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. AWS — S3 (object storage) + Textract (OCR)
# -----------------------------------------------------------------------------
# IAM user `submittal-builder-dev` with programmatic access.
# Policy: s3:ListBucket on arn:aws:s3:::<bucket>,
#         s3:{PutObject,GetObject,DeleteObject} on arn:aws:s3:::<bucket>/*,
#         textract:{StartDocumentTextDetection,GetDocumentTextDetection,DetectDocumentText}.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=us-east-1

# One bucket per environment, same region as Textract to avoid egress.
S3_BUCKET_DEV=submittal-builder-dev
S3_BUCKET_PROD=submittal-builder-prod


# -----------------------------------------------------------------------------
# 2. Neon — Postgres
# -----------------------------------------------------------------------------
# Project: submittal-builder. Branches: main (prod), dev.
# Pooled URL = used by the Next.js web app (serverless).
# Direct URL = used by the worker and by drizzle-kit migrations.
DATABASE_URL_POOLED_DEV=""
DATABASE_URL_DIRECT_DEV=""
DATABASE_URL_POOLED_PROD=""
DATABASE_URL_DIRECT_PROD=""

# The web app reads this (set to *_POOLED_DEV locally).
# Worker and migrations read DATABASE_URL_DIRECT.
DATABASE_URL=""
DATABASE_URL_DIRECT=""


# -----------------------------------------------------------------------------
# 3. Anthropic — Claude API
# -----------------------------------------------------------------------------
# Workspace: submittal-builder. Spend cap set in the Anthropic console.
ANTHROPIC_API_KEY=""

# Model IDs — locked in step-7. Override here if Phase 0 spike pushes to Opus.
ANTHROPIC_CLASSIFY_MODEL=claude-sonnet-4-6
ANTHROPIC_EXTRACT_MODEL=claude-sonnet-4-6


# -----------------------------------------------------------------------------
# 4. Resend — transactional email (signup verification, password reset)
# -----------------------------------------------------------------------------
# Domain verified in Resend (DNS records added at Cloudflare).
RESEND_API_KEY=""
EMAIL_FROM=""
EMAIL_FROM_NAME=Submittal Builder


# -----------------------------------------------------------------------------
# 5. better-auth — sessions, CSRF, password hashing
# -----------------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=""
# The public origin of the web app. Used for cookies, CSRF, email links.
BETTER_AUTH_URL=http://localhost:3000
# Cookie lifetime in seconds (30 days rolling). Don't change without a reason.
SESSION_TTL_SECONDS=2592000


# -----------------------------------------------------------------------------
# 6. Vercel — web hosting (Phase 0 provisioning; not needed for local dev)
# -----------------------------------------------------------------------------
# These are set via the Vercel dashboard for prod/preview; only needed locally
# if you script deployments.
VERCEL_PROJECT_ID=""
VERCEL_ORG_ID=""
VERCEL_TOKEN=""


# -----------------------------------------------------------------------------
# 7. Fly.io — worker hosting
# -----------------------------------------------------------------------------
FLY_API_TOKEN=""
FLY_APP_NAME=submittal-builder-worker


# -----------------------------------------------------------------------------
# 8. Sentry — error tracking (web + worker)
# -----------------------------------------------------------------------------
SENTRY_DSN_WEB=""
SENTRY_DSN_WORKER=""
SENTRY_ORG=""
SENTRY_PROJECT_WEB=submittal-builder-web
SENTRY_PROJECT_WORKER=submittal-builder-worker
# Org-scoped token with project:read + project:releases (for source-map uploads).
SENTRY_AUTH_TOKEN=""
# Build-time env propagated into the Sentry SDK; set per environment.
SENTRY_ENVIRONMENT=development


# -----------------------------------------------------------------------------
# 9. Cloudflare — DNS + edge proxy
# -----------------------------------------------------------------------------
# Mostly configured in the Cloudflare dashboard; record what's set up.
APP_DOMAIN=app.example.com
APP_PUBLIC_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# 10. GitHub — repo + CI
# -----------------------------------------------------------------------------
# Only needed if you generate a PAT for local scripts. CI uses
# GitHub-managed secrets, not this file.
GITHUB_REPO=your-org/submittal-builder


# -----------------------------------------------------------------------------
# 11. pg-boss — queue (re-uses Postgres; no separate creds)
# -----------------------------------------------------------------------------
# Per-topic concurrency limits (overrideable per env). Defaults from step-7 §7.
PGBOSS_CONCURRENCY_OCR=4
PGBOSS_CONCURRENCY_CLASSIFY=8
PGBOSS_CONCURRENCY_EXTRACT=8
PGBOSS_CONCURRENCY_RENDER_EXPORT=2


# -----------------------------------------------------------------------------
# 12. Runtime / feature flags
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
# Worker health endpoint port (Fly checks hit this).
WORKER_HEALTHZ_PORT=8080
# Cap on a single uploaded PDF in bytes (50 MB per scope).
MAX_PDF_BYTES=52428800
# Confidence threshold below which an attribute is flagged "needs review".
CONFIDENCE_REVIEW_THRESHOLD=0.7
