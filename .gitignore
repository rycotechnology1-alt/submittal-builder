# =============================================================================
# Submittal Builder — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# Environment / secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
# Keep `.env.example` checked in.
!.env.example

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
.next/
out/
dist/
build/
*.tsbuildinfo
.turbo/
.cache/

# -----------------------------------------------------------------------------
# Test / coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/

# Vitest
.vitest-cache/

# -----------------------------------------------------------------------------
# Linters / formatters
# -----------------------------------------------------------------------------
.eslintcache
.prettiercache

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Hosting providers
# -----------------------------------------------------------------------------
# Vercel
.vercel/

# Fly.io
.fly/

# -----------------------------------------------------------------------------
# Sentry
# -----------------------------------------------------------------------------
.sentryclirc

# -----------------------------------------------------------------------------
# Drizzle / DB
# -----------------------------------------------------------------------------
# Generated migration metadata — actual SQL migrations ARE checked in.
drizzle/meta/_journal.json.bak
*.db
*.db-journal
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Spike / scratch output (Phase 0 produces PDFs, JSON, images we don't ship)
# -----------------------------------------------------------------------------
spikes/**/output/
spikes/**/*.pdf
spikes/**/*.png
spikes/**/*.webp
spikes/**/*.jpg
# Keep input fixtures.
!spikes/**/fixtures/**

# -----------------------------------------------------------------------------
# IDE / editors
# -----------------------------------------------------------------------------
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Temp / scratch
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.orig
