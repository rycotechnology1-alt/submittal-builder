{
  "name": "submittal-builder",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.10",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "pnpm -r --parallel --filter=./apps/* run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "db:generate": "pnpm --filter @submittal/db run generate",
    "db:migrate": "pnpm --filter @submittal/db run migrate",
    "db:studio": "pnpm --filter @submittal/db run studio",
    "db:seed": "pnpm --filter @submittal/db run seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\" --ignore-path .gitignore",
    "smoke:phase4": "pnpm --filter @submittal/web run smoke:phase4",
    "smoke:e2e": "pnpm --filter @submittal/web run smoke:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.14.10",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^2.1.8"
  }
}
